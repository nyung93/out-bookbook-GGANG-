'use client';

import React, { useState, useEffect } from 'react';
import { motion } from 'framer-motion';
import { BookOpen, RefreshCw, Users, Settings } from 'lucide-react';

// --- 초기 데이터 타입 및 상태 ---
export default function KyodokApp() {
  const [isMounted, setIsMounted] = useState(false);
  const [activeTab, setActiveTab] = useState('status'); // status, spin, manage
  
  // 회차 및 상태 데이터
  const [session, setSession] = useState({
    round: 1,
    startDate: '',
    endDate: '',
    spinsLeft: 3,
  });

  const [members, setMembers] = useState([]);
  
  // 돌림판 애니메이션 상태
  const [rotation, setRotation] = useState(0);
  const [isSpinning, setIsSpinning] = useState(false);

  // Vercel(Next.js) Hydration 에러 방지 및 로컬스토리지 연동
  useEffect(() => {
    setIsMounted(true);
    const savedData = localStorage.getItem('kyodok-data');
    if (savedData) {
      const parsed = JSON.parse(savedData);
      setSession(parsed.session);
      setMembers(parsed.members);
    }
  }, []);

  useEffect(() => {
    if (isMounted) {
      localStorage.setItem('kyodok-data', JSON.stringify({ session, members }));
    }
  }, [session, members, isMounted]);

  // 1. 멤버 추가 및 이미지(캐릭터) 텍스트/이모지 등록 (간소화)
  const addMember = () => {
    const name = prompt('이름을 입력하세요:');
    if (!name) return;
    const character = prompt('캐릭터 이모지나 프로필 URL을 입력하세요 (예: 🦊):') || '👤';
    
    setMembers([...members, {
      id: Date.now(),
      name,
      character,
      books: [],
      currentBook: '',
      progress: 0
    }]);
  };

  // 2. 읽고 싶은 책 등록 (최대 4개)
  const addBook = (memberId) => {
    const member = members.find(m => m.id === memberId);
    if (member.books.length >= 4) {
      alert('책은 최대 4개까지만 등록 가능합니다!');
      return;
    }
    const bookTitle = prompt('읽고 싶은 책 제목을 입력하세요:');
    if (!bookTitle) return;

    setMembers(members.map(m => 
      m.id === memberId ? { ...m, books: [...m.books, bookTitle] } : m
    ));
  };

  // 3. 돌림판 로직 (회차당 3번 제한)
  const startSpin = () => {
    if (session.spinsLeft <= 0) {
      alert('이번 회차의 돌림판 기회를 모두 사용했습니다!');
      return;
    }
    if (isSpinning) return;

    setIsSpinning(true);
    const spinDegrees = Math.floor(Math.random() * 360) + 1440; // 최소 4바퀴 회전
    setRotation(rotation + spinDegrees);
    
    // 돌림판 결과 (랜덤으로 책 할당 시뮬레이션)
    setTimeout(() => {
      setIsSpinning(false);
      setSession({ ...session, spinsLeft: session.spinsLeft - 1 });
      
      // 데모 로직: 멤버들의 currentBook을 랜덤하게 변경
      const updatedMembers = members.map(m => {
        if (m.books.length > 0) {
          const randomBook = m.books[Math.floor(Math.random() * m.books.length)];
          return { ...m, currentBook: randomBook };
        }
        return m;
      });
      setMembers(updatedMembers);
      alert('돌림판 결과가 적용되었습니다!');
    }, 3000);
  };

  // 5. 진행도 업데이트
  const updateProgress = (memberId, value) => {
    setMembers(members.map(m => 
      m.id === memberId ? { ...m, progress: Number(value) } : m
    ));
  };

  if (!isMounted) return <div className="min-h-screen bg-gray-50 flex items-center justify-center">로딩중...</div>;

  return (
    <div className="min-h-screen bg-slate-100 flex justify-center font-sans text-gray-800">
      {/* 모바일 화면 컨테이너 */}
      <div className="w-full max-w-md bg-white shadow-2xl flex flex-col relative overflow-hidden">
        
        {/* 헤더 및 타이틀 */}
        <header className="bg-gradient-to-r from-purple-600 to-indigo-600 text-white p-6 rounded-b-3xl shadow-md z-10">
          <h1 className="text-3xl font-black italic tracking-tight text-center drop-shadow-lg">
            🎡 돌려돌려 교독깡!
          </h1>
          <p className="text-center text-sm mt-2 opacity-90 font-medium">제 {session.round}회차 교환독서</p>
          
          {/* 4. 교환독서 기간 표시 */}
          {session.startDate && session.endDate && (
            <div className="mt-3 bg-white/20 rounded-lg p-2 text-xs text-center backdrop-blur-sm">
              🗓️ {session.startDate} ~ {session.endDate}
            </div>
          )}
        </header>

        {/* 메인 콘텐츠 */}
        <main className="flex-1 p-5 overflow-y-auto pb-24">
          
          {/* 현황 탭 */}
          {activeTab === 'status' && (
            <div className="space-y-6">
              <h2 className="text-xl font-bold flex items-center gap-2"><BookOpen className="text-indigo-600" /> 독서 현황판</h2>
              {members.length === 0 ? (
                <p className="text-gray-400 text-center py-10">관리 탭에서 멤버를 추가해주세요.</p>
              ) : (
                members.map(member => (
                  <div key={member.id} className="bg-white border-2 border-slate-100 rounded-2xl p-4 shadow-sm relative overflow-hidden">
                    <div className="flex justify-between items-end mb-3">
                      <div className="flex items-center gap-3">
                        <div className="text-3xl bg-slate-100 w-12 h-12 rounded-full flex items-center justify-center">{member.character}</div>
                        <div>
                          <p className="font-bold text-lg">{member.name}</p>
                          {/* 6. 지정된 책 및 읽는 사람 라벨 */}
                          {member.currentBook ? (
                            <span className="inline-block bg-indigo-100 text-indigo-700 text-xs px-2 py-1 rounded-md font-semibold mt-1">
                              📖 {member.currentBook}
                            </span>
                          ) : (
                            <span className="text-xs text-gray-400">배정된 책 없음</span>
                          )}
                        </div>
                      </div>
                      <span className="text-sm font-bold text-indigo-600">{member.progress}%</span>
                    </div>
                    
                    {/* 5. 상태 표시 바 및 컨트롤러 */}
                    <div className="w-full bg-slate-100 h-4 rounded-full overflow-hidden mb-2">
                      <motion.div 
                        initial={{ width: 0 }}
                        animate={{ width: `${member.progress}%` }}
                        className="bg-gradient-to-r from-purple-500 to-indigo-500 h-full rounded-full"
                      />
                    </div>
                    <input 
                      type="range" 
                      min="0" max="100" 
                      value={member.progress}
                      onChange={(e) => updateProgress(member.id, e.target.value)}
                      className="w-full accent-indigo-600"
                    />
                  </div>
                ))
              )}
            </div>
          )}

          {/* 돌림판 탭 */}
          {activeTab === 'spin' && (
            <div className="flex flex-col items-center py-8">
              <h2 className="text-xl font-bold mb-2">운명의 돌림판</h2>
              <p className="text-sm text-gray-500 mb-8">남은 기회: <span className="text-indigo-600 font-bold">{session.spinsLeft}번</span></p>
              
              <div className="relative w-72 h-72">
                {/* 화살표 핀 */}
                <div className="absolute -top-4 left-1/2 -translate-x-1/2 w-0 h-0 border-l-[15px] border-r-[15px] border-t-[30px] border-l-transparent border-r-transparent border-t-red-500 z-20 drop-shadow-md" />
                
                {/* 돌림판 그래픽 */}
                <motion.div
                  animate={{ rotate: rotation }}
                  transition={{ duration: 3, ease: "circOut" }}
                  className="w-full h-full rounded-full border-8 border-indigo-200 shadow-inner flex items-center justify-center overflow-hidden"
                  style={{ background: 'conic-gradient(#818cf8 0deg 90deg, #c7d2fe 90deg 180deg, #6366f1 180deg 270deg, #a5b4fc 270deg 360deg)' }}
                >
                  <div className="w-16 h-16 bg-white rounded-full flex items-center justify-center shadow-lg z-10 font-bold text-indigo-600">
                    SPIN
                  </div>
                </motion.div>
              </div>

              <button 
                onClick={startSpin}
                disabled={isSpinning || session.spinsLeft === 0}
                className="mt-12 w-full py-4 bg-indigo-600 disabled:bg-slate-400 text-white rounded-2xl font-black text-lg shadow-xl active:scale-95 transition-transform"
              >
                {isSpinning ? '두구두구두구...' : '돌리기 시작!'}
              </button>
            </div>
          )}

          {/* 관리 탭 */}
          {activeTab === 'manage' && (
            <div className="space-y-6">
              <div className="bg-indigo-50 p-4 rounded-2xl border border-indigo-100">
                <h3 className="font-bold flex items-center gap-2 mb-3"><Settings size={18} /> 회차 설정</h3>
                <div className="flex gap-2 text-sm">
                  <input type="date" className="flex-1 p-2 rounded-lg border" value={session.startDate} onChange={e => setSession({...session, startDate: e.target.value})} />
                  <span className="self-center">~</span>
                  <input type="date" className="flex-1 p-2 rounded-lg border" value={session.endDate} onChange={e => setSession({...session, endDate: e.target.value})} />
                </div>
                <button onClick={() => setSession({...session, spinsLeft: 3, round: session.round + 1})} className="mt-3 w-full py-2 bg-indigo-200 text-indigo-800 font-bold rounded-lg">
                  새로운 회차 시작 (돌림판 초기화)
                </button>
              </div>

              <div>
                <div className="flex justify-between items-center mb-4">
                  <h3 className="font-bold flex items-center gap-2"><Users size={18} /> 멤버 및 도서 관리</h3>
                  <button onClick={addMember} className="bg-indigo-600 text-white text-sm px-3 py-1 rounded-full font-bold">+ 멤버 추가</button>
                </div>
                
                <div className="space-y-3">
                  {members.map(member => (
                    <div key={member.id} className="p-3 border rounded-xl bg-white">
                      <div className="flex justify-between items-center border-b pb-2 mb-2">
                        <span className="font-bold">{member.character} {member.name}</span>
                        <button onClick={() => addBook(member.id)} className="text-xs bg-slate-100 px-2 py-1 rounded-md text-slate-600 font-bold">
                          + 책 추가 ({member.books.length}/4)
                        </button>
                      </div>
                      <ul className="text-sm text-slate-600 space-y-1 pl-2">
                        {member.books.length === 0 && <li className="text-slate-400">등록된 책이 없습니다.</li>}
                        {member.books.map((b, i) => <li key={i}>- {b}</li>)}
                      </ul>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          )}
        </main>

        {/* 하단 탭 네비게이션 */}
        <nav className="absolute bottom-0 w-full bg-white border-t rounded-t-2xl flex pb-safe shadow-[0_-4px_20px_rgba(0,0,0,0.05)] z-20">
          {[
            { id: 'status', icon: <BookOpen size={20} />, label: '현황판' },
            { id: 'spin', icon: <RefreshCw size={20} />, label: '돌림판' },
            { id: 'manage', icon: <Settings size={20} />, label: '설정/관리' }
          ].map((tab) => (
            <button
              key={tab.id}
              onClick={() => setActiveTab(tab.id)}
              className={`flex-1 flex flex-col items-center justify-center py-4 gap-1 transition-colors ${
                activeTab === tab.id ? 'text-indigo-600 font-bold' : 'text-gray-400 font-medium'
              }`}
            >
              {tab.icon}
              <span className="text-xs">{tab.label}</span>
            </button>
          ))}
        </nav>
      </div>
    </div>
  );
}
